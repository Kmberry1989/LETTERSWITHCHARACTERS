# PostgreSQL connection string used by Prisma.
# Local example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/letters_with_characters?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Supabase client configuration for @supabase/ssr.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_REPLACE_ME"

# Optional Genkit / Google AI configuration can be added here when AI hints are enabled.
